# OnChord Environment Variables
# Copy this file to .env and fill in your values
# Required for: docker compose up

# =============================================================================
# SUPABASE (Frontend)
# =============================================================================
# Get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# SPOTIFY (Frontend - PKCE OAuth flow)
# =============================================================================
# Get your Client ID from: https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
VITE_SPOTIFY_REDIRECT_URI=http://localhost:3000/settings

# =============================================================================
# TICKETMASTER (Frontend)
# =============================================================================
# Get your API key from: https://developer.ticketmaster.com/
VITE_TICKETMASTER_API_KEY=your_ticketmaster_api_key

# =============================================================================
# ML SERVICE
# =============================================================================
VITE_ML_SERVICE_URL=http://localhost:8000

# =============================================================================
# LAST.FM API (ML Service)
# =============================================================================
# Get a free API key at: https://www.last.fm/api/account/create
# Used for genre lookups when artist data is not in local database
LASTFM_API_KEY=your_lastfm_api_key_here
