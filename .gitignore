# ===========================================
# OnChord Project - Git Ignore
# ===========================================

# -------------------------------------------
# Dependencies
# -------------------------------------------
node_modules/
.pnpm-store/

# -------------------------------------------
# Environment variables
# -------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# -------------------------------------------
# Build outputs
# -------------------------------------------
dist/
build/
.vite/
*.tsbuildinfo

# -------------------------------------------
# Python / ML Service
# -------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg
.venv/
venv/
ENV/
env/
.ipynb_checkpoints/

# ML data files (large datasets)
ml-service/data/*.csv
ml-service/data/*.parquet
ml-service/data/*.json
!ml-service/data/.gitignore

# Trained models (large files - don't track)
ml-service/models/*.joblib
ml-service/models/*.pkl

# -------------------------------------------
# IDE / Editor
# -------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# -------------------------------------------
# Logs
# -------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------------------------
# Testing
# -------------------------------------------
coverage/
.nyc_output/
.pytest_cache/

# -------------------------------------------
# Misc
# -------------------------------------------
*.local
.cache/
.temp/
.tmp/

# -------------------------------------------
# Project Info (optional - academic docs)
# -------------------------------------------
# Uncomment if you don't want to track reports/slides
# Project Info/
ml-service/models/algorithm_comparison_results.csv
